# Avoid 404 errors for favicon
RewriteRule ^favicon\.ico$ - [L]

# ---------------------------------------------------------
# ✅ Fix MIME type for JS files
# ---------------------------------------------------------
AddType application/javascript .js
AddType text/vcard .vcf


# ---------------------------------------------------------
# ✅ Enable URL Rewriting
# ---------------------------------------------------------
RewriteEngine On
RewriteBase /vcard/

# ---------------------------------------------------------
# ✅ Allow direct access to employee CRUD pages
# ---------------------------------------------------------
RewriteRule ^([a-zA-Z0-9_-]+)/create_employee\.php$ create_employee.php [L,QSA]
RewriteRule ^([a-zA-Z0-9_-]+)/edit_employee\.php$ edit_employee.php [L,QSA]
RewriteRule ^([a-zA-Z0-9_-]+)/delete_employee\.php$ delete_employee.php [L,QSA]
RewriteRule ^([a-zA-Z0-9_-]+)/save_employee\.php$ save_employee.php [L,QSA]
RewriteRule ^([a-zA-Z0-9_-]+)/update_employee\.php$ update_employee.php [L,QSA]
RewriteRule ^([a-zA-Z0-9_-]+)/overview\.php$ overview.php [L,QSA]

# ---------------------------------------------------------
# ✅ Let existing files/folders (assets, uploads, JS, CSS) pass through
# ---------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ---------------------------------------------------------
# ✅ Public employee card
# ---------------------------------------------------------
RewriteRule ^([a-zA-Z0-9_-]+)/([a-zA-Z0-9_-]+)/?$ view.php?company=$1&employee=$2 [L,QSA]

# ---------------------------------------------------------
# ✅ Company dashboard
# ---------------------------------------------------------
RewriteRule ^([a-zA-Z0-9_-]+)/?$ dashboard.php?company=$1 [L,QSA]
